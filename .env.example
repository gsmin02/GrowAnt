# PostgreSQL (мһҗмІҙ нҳёмҠӨнҢ… вҖ” docker composeмқҳ postgres м»Ён…Ңмқҙл„Ҳ)
# нҳёмҠӨнҠём—җм„ң backendлҘј м§Ғм ‘ мӢӨн–ү(bootRun)н•  л•Ңмқҳ м ‘мҶҚ мЈјмҶҢ. м»Ён…Ңмқҙл„Ҳ м•Ҳм—җм„ңлҠ” composeк°Җ DB_URLмқ„ лҚ®м–ҙм“ҙлӢӨ.
DB_URL=jdbc:postgresql://localhost:5432/growant
DB_USER=growant
DB_PASSWORD=growant

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AI (Gemini)
GEMINI_API_KEY=__change_me__

# Auth
JWT_SECRET=__change_me__

# Social OAuth (placeholder)
KAKAO_CLIENT_ID=
NAVER_CLIENT_ID=
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Market data source: sim | kis
MARKET_PROVIDER=sim
