# Supabase (managed Postgres) — 풀러(Supavisor) 트랜잭션 모드 권장
SUPABASE_DB_URL=jdbc:postgresql://<PROJECT>.pooler.supabase.com:6543/postgres
SUPABASE_DB_USER=postgres.<PROJECT>
SUPABASE_DB_PASSWORD=__change_me__

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AI (Gemini)
GEMINI_API_KEY=__change_me__

# Auth
JWT_SECRET=__change_me__

# Social OAuth (placeholder)
KAKAO_CLIENT_ID=
NAVER_CLIENT_ID=
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Market data source: sim | kis
MARKET_PROVIDER=sim
